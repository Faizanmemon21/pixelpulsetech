# ------------------------------------------------------------------
# Chat widget (api/chat.ts) — set these in your Vercel project's
# Settings -> Environment Variables. Not needed for local `npm run dev`
# (the widget will show a friendly "not configured yet" error until set);
# to test the API route locally, use `vercel dev` instead of `vite`.
# ------------------------------------------------------------------

# Any OpenAI-compatible provider works via the official OpenAI SDK.
# Recommended for a free/cheap start: OpenRouter (https://openrouter.ai).
#   AI_API_KEY  = your OpenRouter API key (sk-or-...)
#   AI_BASE_URL = https://openrouter.ai/api/v1
#   AI_MODEL    = e.g. meta-llama/llama-4-maverick:free (free) or a paid model
# For OpenAI directly: leave AI_BASE_URL empty and use an OpenAI key/model.
AI_API_KEY=
AI_MODEL=
AI_BASE_URL=

# Optional. Signs the guest daily-usage cookie. Works without it (a fallback
# secret is baked in) — set your own random string in production so the
# free-message counter can't be casually reset by reading the source.
CHAT_COOKIE_SECRET=

# Optional. Shared daily message allowance for the whole site (no accounts
# here, so this is one bucket per visitor's cookie). Default: 40.
CHAT_DAILY_LIMIT=40

# ------------------------------------------------------------------
# Store Admin backend (api/admin/*, #/admin page) — manage products,
# prices and photos with a login instead of editing code. See ADMIN_SETUP.md.
# Requires a Vercel Blob store (Storage -> Create -> Blob), which adds
# BLOB_READ_WRITE_TOKEN automatically. Admin only runs on Vercel, not `vite`.
# ------------------------------------------------------------------

# The password you type to log in at /#/admin. Pick a strong one.
ADMIN_PASSWORD=
# Any long random string — signs the admin session cookie.
ADMIN_SESSION_SECRET=
